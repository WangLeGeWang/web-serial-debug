{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BUS Studio",
  "version": "4.1.0",
  "identifier": "com.busstudio.app",
  "build": {
    "beforeDevCommand": "npm --prefix ../.. run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix ../.. run build",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BUS Studio",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
